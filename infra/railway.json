{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "web": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/Dockerfile.web"
      },
      "deploy": {
        "startCommand": "bun run --cwd apps/web start",
        "healthcheckPath": "/install.sh",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "api": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/Dockerfile.api"
      },
      "deploy": {
        "startCommand": "bun run --cwd apps/api start",
        "healthcheckPath": "/healthz",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    "worker": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/Dockerfile.worker"
      },
      "deploy": {
        "startCommand": "bun run --cwd apps/worker start",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    }
  }
}
