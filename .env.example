# Postgres connection string for every service (local dev: docker compose Postgres).
# In production: point this at the app_bematist role (NOBYPASSRLS, created by
# WS-1's 0003_rls.sql). Migrations run separately under a superuser.
DATABASE_URL=

# Optional admin connection string for the web app's one cross-tenant lookup
# (resolve better_auth_user_id -> org). Must be a role that can SELECT from
# `users` without an `app.current_org_id` set (superuser in dev; a dedicated
# auth-lookup role in prod). Falls back to DATABASE_URL when unset.
ADMIN_DATABASE_URL=

# GitHub App credentials (WS-5)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Better-Auth (WS-4)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
BETTER_AUTH_TRUSTED_ORIGINS=

# GitHub OAuth App credentials for dashboard sign-in (WS-4, distinct from
# the GITHUB_APP_* credentials above which are for the webhook-receiving
# GitHub App in WS-5). Scopes requested: read:user, public_repo.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Base URL of the ingest API used by the web app and the ingest binary
INGEST_API_URL=
