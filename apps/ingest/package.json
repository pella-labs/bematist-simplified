{
  "name": "@bematist/ingest",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:binary": "bun run build.ts",
    "build:darwin-arm64": "bun run build.ts darwin-arm64",
    "build:darwin-x64": "bun run build.ts darwin-x64",
    "build:linux-x64": "bun run build.ts linux-x64",
    "build:win32-x64": "bun run build.ts win32-x64"
  },
  "dependencies": {
    "@bematist/contracts": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
