{
  "name": "@bematist/ingest",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile=dist/bematist-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile=dist/bematist-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile=dist/bematist-linux-x64",
    "build:win32-x64": "bun build --compile --target=bun-windows-x64 ./src/index.ts --outfile=dist/bematist-win32-x64.exe"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
